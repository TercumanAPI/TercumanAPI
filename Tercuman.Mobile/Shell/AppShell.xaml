<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Tercuman.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dashboard="clr-namespace:Tercuman.Mobile.Features.Dashboard.Views"
    xmlns:ads="clr-namespace:Tercuman.Mobile.Features.Ads.Views"
    xmlns:auth="clr-namespace:Tercuman.Mobile.Features.Auth.Views"
    xmlns:profile="clr-namespace:Tercuman.Mobile.Features.Profile.Views"
    xmlns:messages="clr-namespace:Tercuman.Mobile.Features.Messages.Views"
    FlyoutBackgroundColor="#1E293B" 
    FlyoutHeaderBehavior="Fixed"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="30,50,20,30" BackgroundColor="#1E293B">
            <Label Text="MiftahTEA" FontSize="22" FontAttributes="Bold" TextColor="White"/>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Giriş Yap" Icon="login_icon.png" FlyoutItemIsVisible="True">
        <ShellContent ContentTemplate="{DataTemplate auth:LoginPage}" Route="LoginPage" />
    </FlyoutItem>

    <FlyoutItem Title="Ana Sayfa" Icon="home.png">
        <ShellContent ContentTemplate="{DataTemplate dashboard:DashboardPage}" Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Profilim" Icon="profile1.png">
        <ShellContent ContentTemplate="{DataTemplate profile:ProfilePage}" Route="ProfilePage" />
    </FlyoutItem>

    <FlyoutItem Title="Mesajlarım" Icon="messages1.png">
        <ShellContent ContentTemplate="{DataTemplate messages:MessagesPage}" Route="MessagesPage" />
    </FlyoutItem>

    <FlyoutItem Title="İlan Oluştur" Icon="add1.png">
        <ShellContent ContentTemplate="{DataTemplate ads:CreateAdPage}" Route="CreateAdPage" />
    </FlyoutItem>

    <ShellItem FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate auth:RegisterPage}" Route="RegisterPage" />
    </ShellItem>

    <MenuItem Text="🚪 Çıkış Yap" Command="{Binding LogoutCommand}" />

</Shell>