<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Tercuman.Mobile.Features.Listings.ViewModels"
             xmlns:conv="clr-namespace:Tercuman.Mobile.Shared.Converters"
             x:Class="Tercuman.Mobile.Features.Listings.Views.CreateListingPage"
             Title="Yeni İlan Oluştur"
             BackgroundColor="#F9FAFB">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:IntToBoolConverter x:Key="IntToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding CurrentStep, StringFormat='Adım {0} / 3'}" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold" 
                   TextColor="#6366F1" 
                   FontSize="18"/>

            <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}" Spacing="10">
                <Label Text="Kaynak Dil" FontAttributes="Bold"/>
                <Entry Text="{Binding SourceLanguage}" Placeholder="Örn: Türkçe" BackgroundColor="White"/>

                <Label Text="Hedef Dil" Margin="0,10,0,0" FontAttributes="Bold"/>
                <Entry Text="{Binding TargetLanguage}" Placeholder="Örn: İngilizce" BackgroundColor="White"/>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}" Spacing="10">
                <Label Text="İlan Başlığı" FontAttributes="Bold"/>
                <Entry Text="{Binding Title}" Placeholder="İşle ilgili kısa başlık" BackgroundColor="White"/>

                <Label Text="Açıklama" Margin="0,10,0,0" FontAttributes="Bold"/>
                <Editor Text="{Binding Description}" Placeholder="Deneyimlerinizi anlatın..." HeightRequest="150" BackgroundColor="White"/>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}" Spacing="10">
                <Label Text="Ücretlendirme (TL)" FontAttributes="Bold"/>
                <Entry Text="{Binding Price}" Keyboard="Numeric" Placeholder="0.00" BackgroundColor="White"/>

                <Button Text="İlanı Yayınla" 
                        Command="{Binding SubmitListingCommand}" 
                        BackgroundColor="Green" 
                        TextColor="White"
                        FontAttributes="Bold"
                        Margin="0,20,0,0"
                        HeightRequest="50"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,20,0,0">
                <Button Grid.Column="0" 
                        Text="Geri" 
                        Command="{Binding PreviousStepCommand}" 
                        BackgroundColor="#E5E7EB" 
                        TextColor="#374151"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter='not1'}"/>

                <Button Grid.Column="1" 
                        Text="İleri" 
                        Command="{Binding NextStepCommand}" 
                        BackgroundColor="#6366F1" 
                        TextColor="White"
                        IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter='not3'}"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>