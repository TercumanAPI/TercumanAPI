<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Tercuman.Mobile.Features.Messages.ViewModels"
             xmlns:models="clr-namespace:Tercuman.Mobile.Features.Messages.Models"
             x:Class="Tercuman.Mobile.Features.Messages.Views.MessagesPage"
             x:DataType="viewmodels:MessagesViewModel"
             Title="Mesajlarım"
             BackgroundColor="#F8FAFC">

    <RefreshView IsRefreshing="{Binding IsBusy}" 
                 Command="{Binding RefreshCommand}"
                 RefreshColor="#6366F1">

        <CollectionView ItemsSource="{Binding Conversations}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedConversation}">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" 
                         HorizontalOptions="Center" 
                         Padding="30"
                         Spacing="15">

                    <Image Source="message1.svg" 
               HeightRequest="120" 
               WidthRequest="120"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="0,0,0,10" />

                    <Label Text="Henüz hiç mesajınız yok." 
               FontAttributes="Bold"
               FontSize="18"
               TextColor="#475569"
               HorizontalTextAlignment="Center"/>

                    

                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ConversationListItem">
                    <Grid Padding="15" ColumnDefinitions="Auto, *, Auto">

                        <Frame HeightRequest="55" WidthRequest="55" 
                               CornerRadius="27.5" Padding="0" 
                               IsClippedToBounds="True"
                               HasShadow="False"
                               BorderColor="#E2E8F0">
                            <Image Source="{Binding OtherUserImageUrl, FallbackValue='user_placeholder.png'}" 
                                   Aspect="AspectFill"/>
                        </Frame>

                        <VerticalStackLayout Grid.Column="1" 
                                             VerticalOptions="Center" 
                                             Margin="15,0,0,0"
                                             Spacing="2">
                            <Label Text="{Binding OtherUserName}" 
                                   FontAttributes="Bold" 
                                   FontSize="16"
                                   TextColor="#1E293B"/>
                            <Label Text="{Binding LastMessage}" 
                                   TextColor="#64748B" 
                                   MaxLines="1" 
                                   FontSize="13"
                                   LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" 
                                             VerticalOptions="Center" 
                                             HorizontalOptions="End">
                            <Label Text="{Binding LastMessageDate, StringFormat='{0:HH:mm}'}" 
                                   FontSize="11" 
                                   TextColor="#94A3B8"/>
                        </VerticalStackLayout>

                        <BoxView Grid.Row="1" Grid.ColumnSpan="3" 
                                 HeightRequest="1" 
                                 BackgroundColor="#F1F5F9" 
                                 VerticalOptions="End" 
                                 Margin="0,10,-15,0"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>