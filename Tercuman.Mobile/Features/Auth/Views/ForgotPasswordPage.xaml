<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tercuman.Mobile.Features.Auth.Views.ForgotPasswordPage"
             BackgroundColor="#F5F7FF"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20" VerticalOptions="Center">

            <Label Text="MiftahTEA" 
                   TextColor="#6366F1" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,40,0,30"/>

            <Frame CornerRadius="20" HasShadow="True" BorderColor="Transparent" Padding="25" BackgroundColor="White" Margin="10,0,10,20">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Şifremi Unuttum" 
                           FontSize="24" 
                           TextColor="#1E293B" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"/>

                    <Label Text="Lütfen hesabınıza kayıtlı e-posta adresinizi girin. Size bir sıfırlama bağlantısı göndereceğiz." 
                           FontSize="14" 
                           TextColor="#64748B" 
                           HorizontalOptions="Center" 
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,10"/>

                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" Padding="10,2">
                        <Entry Placeholder="E-mail adresiniz" 
                               Text="{Binding Email}" 
                               Keyboard="Email"
                               TextColor="#1E293B" 
                               PlaceholderColor="#94A3B8" 
                               BackgroundColor="Transparent"/>
                    </Border>

                    <Button Text="Bağlantı Gönder" 
                            Command="{Binding SendResetLinkCommand}"
                            BackgroundColor="#512BD4" 
                            TextColor="White" 
                            CornerRadius="12" 
                            HeightRequest="55" 
                            FontAttributes="Bold"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                        <Label Text="Hatırladınız mı?" FontSize="14" TextColor="#64748B"/>
                        <Label Text="Giriş Yapın" 
                               TextColor="#6366F1" 
                               FontAttributes="Bold" 
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>