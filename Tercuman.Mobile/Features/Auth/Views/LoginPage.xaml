<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tercuman.Mobile.Features.Auth.Views.LoginPage"
             BackgroundColor="#F5F7FF"
             Shell.FlyoutBehavior="Flyout"
             Shell.NavBarIsVisible="True"
             Shell.NavBarHasShadow="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20" VerticalOptions="Center">

            <Label Text="MiftahTEA" 
                   TextColor="#6366F1" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,40,0,30"/>

            <Frame CornerRadius="20" 
                   HasShadow="True" 
                   BorderColor="Transparent"
                   Padding="25" 
                   BackgroundColor="White"
                   Margin="10,0,10,20">

                <VerticalStackLayout Spacing="15">
                    <Label Text="Giriş Yapın" 
                           FontSize="24" 
                           TextColor="#1E293B"
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10"/>

                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" Padding="10,2">
                        <Entry Placeholder="E-mail adresiniz" 
                               Text="{Binding Email}" 
                               Keyboard="Email"
                               TextColor="#1E293B" 
                               PlaceholderColor="#94A3B8" 
                               BackgroundColor="Transparent"/>
                    </Border>

                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" Padding="10,2">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry Placeholder="******" 
                                   IsPassword="True" 
                                   Text="{Binding Password}" 
                                   TextColor="#1E293B" 
                                   PlaceholderColor="#94A3B8" 
                                   BackgroundColor="Transparent"/>
                            <Image Grid.Column="1" 
                                   Source="eye_icon.png" 
                                   WidthRequest="20" 
                                   VerticalOptions="Center" 
                                   Margin="0,0,5,0"/>
                        </Grid>
                    </Border>

                    <Label Text="Parolanızı mı unuttunuz?" 
                           TextColor="#6366F1" 
                           HorizontalOptions="End" 
                           FontSize="12" 
                           Margin="0,-5,0,10">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <Button Text="Giriş Yapın" 
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#512BD4" 
                            TextColor="White" 
                            CornerRadius="12"
                            HeightRequest="55"
                            FontSize="16"
                            FontAttributes="Bold"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6366F1" HorizontalOptions="Center"/>

                    <Label Text="Veya şununla giriş yapın:" 
                           HorizontalOptions="Center" 
                           FontSize="13" 
                           TextColor="#64748B" 
                           Margin="0,15,0,0"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="25" Margin="0,10,0,0">
                        <Image Source="google_icon.png" WidthRequest="35" HeightRequest="35"/>
                        <Image Source="apple_icon.png" WidthRequest="35" HeightRequest="35"/>
                        <Image Source="twitter_icon.png" WidthRequest="35" HeightRequest="35"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,20,0,0">
                        <Label Text="Hesabınız yok mu?" FontSize="14" TextColor="#64748B"/>
                        <Label Text="Kayıt Olun" 
                               TextColor="#6366F1" 
                               FontAttributes="Bold" 
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>