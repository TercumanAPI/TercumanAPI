<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tercuman.Mobile.Features.Dashboard.Views.DashboardPage"
             BackgroundColor="#F8FAFC"
             Title="MiftahTEA"
             Shell.NavBarIsVisible="True"
             Shell.FlyoutBehavior="Flyout">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Frame BackgroundColor="#6366F1" CornerRadius="20" HasShadow="True" Padding="25" BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Hoş Geldiniz," TextColor="White" FontSize="24" FontAttributes="Bold"/>
                        <Label Text="👋" FontSize="24"/>
                    </HorizontalStackLayout>
                    <Label Text="MiftahTEA uzmanlarıyla çeviri süreçlerinizi kolayca yönetin." 
                           TextColor="#E0E7FF" FontSize="14" LineBreakMode="WordWrap"/>

                    <Button Text="Yeni Çevirmen Keşfet →" 
                            BackgroundColor="Transparent" 
                            TextColor="White" 
                            FontSize="13" 
                            FontAttributes="Bold"
                            HorizontalOptions="Start"
                            Padding="0"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15" RowSpacing="15">

                <Frame Grid.Row="0" Grid.Column="0" CornerRadius="15" Padding="15" BorderColor="#E2E8F0" BackgroundColor="White">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="0" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center"/>
                        <Label Text="Aktif Sipariş" FontSize="12" TextColor="#64748B" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" CornerRadius="15" Padding="15" BorderColor="#E2E8F0" BackgroundColor="White">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="0" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center"/>
                        <Label Text="Tamamlanan" FontSize="12" TextColor="#64748B" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.ColumnSpan="2" 
           CornerRadius="15" 
           Padding="20" 
           BorderColor="#6366F1" 
           BackgroundColor="White">
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCreateAdCommand}"/>
                        </HorizontalStackLayout.GestureRecognizers>

                        <Label Text="+" FontSize="30" FontAttributes="Bold" TextColor="#6366F1" VerticalOptions="Center"/>
                        <Label Text="Yeni İlan Oluştur" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="0" CornerRadius="15" Padding="15" BorderColor="#E2E8F0" BackgroundColor="White">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="0" FontSize="24" FontAttributes="Bold" TextColor="#6366F1" HorizontalOptions="Center"/>
                        <Label Text="Mesajlar" FontSize="12" TextColor="#64748B" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="1" CornerRadius="15" Padding="15" BorderColor="#E2E8F0" BackgroundColor="White">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="0" FontSize="24" FontAttributes="Bold" TextColor="#EF4444" HorizontalOptions="Center"/>
                        <Label Text="Favoriler" FontSize="12" TextColor="#64748B" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <VerticalStackLayout Spacing="10">
                <HorizontalStackLayout Spacing="5">
                    <Label Text="⭐" FontSize="16" VerticalOptions="Center"/>
                    <Label Text="Favori Çevirmenlerim" FontSize="18" FontAttributes="Bold" TextColor="#1E293B"/>
                </HorizontalStackLayout>

                <Frame BorderColor="#E2E8F0" CornerRadius="15" Padding="30" BackgroundColor="White" HasShadow="False">
                    <Label Text="Henüz favorinize eklediğiniz bir çevirmen bulunmuyor." 
                           TextColor="#94A3B8" FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </Frame>
                
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>