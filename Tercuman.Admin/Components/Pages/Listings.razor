@page "/listings"
@using MudBlazor
@using Tercuman.Application.DTOs.Listing
@using Tercuman.Admin.Services
@inject ApiService ApiService

<MudText Typo="Typo.h4" Class="mb-4">Listings</MudText>

<MudTextField @bind-Value="searchKeyword"
              Placeholder="Search listings..."
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true"
              OnBlur="SearchListings"
              Class="mb-4" />

<MudTable T="ListingDto"
          @ref="table"
          ServerData="LoadListings"
          Hover="true"
          Striped="true"
          Dense="true">

    <HeaderContent>
        <MudTh>Listing No</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>City</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>

    <RowTemplate>

        <MudTd>@context.ListingNo</MudTd>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.Price</MudTd>
        <MudTd>@context.City</MudTd>

        <MudTd>

            <MudButton Color="Color.Error"
                       Variant="Variant.Filled"
                       OnClick="@(() => DeleteListing(context.Id))">
                Delete
            </MudButton>

        </MudTd>

    </RowTemplate>

</MudTable>

@code {

    MudTable<ListingDto> table;

    string searchKeyword = "";

    private async Task<TableData<ListingDto>> LoadListings(
        TableState state,
        CancellationToken token)
    {
        int page = state.Page + 1;
        int pageSize = state.PageSize;

        // SEARCH
        if (!string.IsNullOrWhiteSpace(searchKeyword))
        {
            var searchResult = await ApiService.SearchListings(searchKeyword);

            return new TableData<ListingDto>
            {
                Items = searchResult,
                TotalItems = searchResult.Count
            };
        }

        // NORMAL LIST
        var result = await ApiService.GetListings(page, pageSize);

        return new TableData<ListingDto>
        {
            Items = result.Item1,
            TotalItems = result.Item2
        };
    }

    async Task DeleteListing(Guid id)
    {
        await ApiService.DeleteListing(id);

        if (table != null)
            await table.ReloadServerData();
    }

    async Task SearchListings()
    {
        if (table != null)
            await table.ReloadServerData();
    }

}