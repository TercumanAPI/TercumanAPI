@page "/dashboard"
@using MudBlazor
@using Tercuman.Admin.Services
@inject ApiService ApiService

<MudText Typo="Typo.h4" Class="mb-4">Admin Dashboard</MudText>

<MudGrid>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Total Users</MudText>
                <MudText Typo="Typo.h4">@totalUsers</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Total Listings</MudText>
                <MudText Typo="Typo.h4">@totalListings</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Messages</MudText>
                <MudText Typo="Typo.h4">@totalMessages</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">Reviews</MudText>
                <MudText Typo="Typo.h4">@totalReviews</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudPaper Class="mt-6 pa-4">

        <MudText Typo="Typo.h6">Platform Growth</MudText>

        <MudChart ChartType="ChartType.Line"
                  ChartSeries="@series"
                  XAxisLabels="@labels"
                  Width="100%"
                  Height="350px" />

    </MudPaper>

</MudGrid>

@code {

    int totalUsers;
    int totalListings;
    int totalMessages;
    int totalReviews;

    protected override async Task OnInitializedAsync()
    {
        totalUsers = await ApiService.GetUserCount();
        totalListings = await ApiService.GetListingCount();
        totalMessages = await ApiService.GetMessageCount();
        totalReviews = await ApiService.GetReviewCount();
    }
    List<ChartSeries> series = new();
    string[] labels;


    void LoadChart()
    {
        labels = new string[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun" };

        series = new List<ChartSeries>()
    {
        new ChartSeries
        {
            Name = "Users",
            Data = new double[] { 10, 30, 50, 80, 120, 150 }
        },

        new ChartSeries
        {
            Name = "Listings",
            Data = new double[] { 5, 20, 40, 70, 110, 140 }
        }
    };
    }
}